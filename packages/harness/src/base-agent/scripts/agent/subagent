#!/usr/bin/env bash
# Wrapper around `pi -p` for spawning sub-agents.
#
# Why this exists: a bare `pi -p` falls back to pi's *global* default model
# (`~/.pi/agent/settings.json`), not this agent's configured model. The
# harness exports the agent's sub-agent model as PI_SUBAGENT_PROVIDER /
# PI_SUBAGENT_MODEL / PI_SUBAGENT_THINKING (from `subagentModel ?? model` in
# agent.json). This wrapper turns those into --provider/--model/--thinking so
# every sub-agent runs on the configured model. The agent may still override
# per call by passing --provider/--model/--thinking explicitly.
#
# Usage is identical to `pi -p` — all args are forwarded verbatim:
#   scripts/agent/subagent "Read /repo/x.ts and list issues" \
#     --session-dir "sessions/<threadId>/subagents/<subAgentId>" \
#     --system-prompt "..." --tools "read,grep"
set -euo pipefail

has_flag() {
  local want="$1"; shift
  for a in "$@"; do
    [ "$a" = "$want" ] && return 0
  done
  return 1
}

extra=()
# The wrapper owns the sub-agent's system prompt: the shared base prompt
# (tools, files, workspace, sessions, web, browser) plus the sub-agent role
# prompt ("stdout is your return value", stay scoped). The caller never passes
# --system-prompt — the task-specific brief goes in the message (positional
# arg), so it lives in the session history and survives resume. --system-prompt
# takes a single value (not repeatable), so we concat the two files and pass
# the combined text. We use --system-prompt (not --append-system-prompt) so the
# prompt is exactly these two files; appending would layer them onto pi's
# default SYSTEM.md/built-in, leaking unrelated context. Set on every call
# including -c/--continue: pi does not persist the system prompt to the session
# JSONL, so on resume it must be re-injected — same as the main agent's prompt
# is re-passed on every spawn.
AGENT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
BASE_PROMPT="$AGENT_DIR/system_prompts/0-base_prompt.md"
SUBAGENT_PROMPT="$AGENT_DIR/scripts/agent/sub-agent-prompt.md"
sys_prompt=""
[ -f "$BASE_PROMPT" ] && sys_prompt="$(cat "$BASE_PROMPT")"
[ -f "$SUBAGENT_PROMPT" ] && sys_prompt="${sys_prompt:+$sys_prompt$'\n\n'}$(cat "$SUBAGENT_PROMPT")"
[ -n "$sys_prompt" ] && extra+=(--system-prompt "$sys_prompt")

# --model "provider/id" already encodes the provider, so only add --provider
# when neither --model nor --provider was passed by the caller.
if [ -n "${PI_SUBAGENT_PROVIDER:-}" ] \
  && ! has_flag --model "$@" && ! has_flag --provider "$@"; then
  extra+=(--provider "$PI_SUBAGENT_PROVIDER")
fi
if [ -n "${PI_SUBAGENT_MODEL:-}" ] && ! has_flag --model "$@"; then
  extra+=(--model "$PI_SUBAGENT_MODEL")
fi
if [ -n "${PI_SUBAGENT_THINKING:-}" ] && ! has_flag --thinking "$@"; then
  extra+=(--thinking "$PI_SUBAGENT_THINKING")
fi

# Pass the task brief (first positional arg) to pi on stdin, not as argv.
# pi -p reads its prompt from stdin when no positional message is given, and
# treats every positional as a *separate* user message. If the brief contains
# a literal unescaped quote (e.g. an email body the model pasted in), the shell
# word-splits the single intended arg into many argv entries, each of which pi
# then replays as its own turn. Routing the brief through stdin sidesteps argv
# entirely, so quoting inside the brief can't fan out into phantom messages.
# Flags (--session-dir, --tools, -c, ...) still go through argv verbatim, and
# the caller interface is unchanged: callers still pass `subagent "<brief>" --flags`.
# ponytail: first non-flag arg is the brief by the documented contract; a brief
# that literally starts with "-" would be misread as a flag — none do today.
# ${extra[@]+...} guards the empty-array expansion under `set -u`.
if [ $# -gt 0 ] && [ "${1#-}" = "$1" ]; then
  msg="$1"; shift
  exec pi -p ${extra[@]+"${extra[@]}"} "$@" <<<"$msg"
fi
exec pi -p ${extra[@]+"${extra[@]}"} "$@"
