{
  "name": "@cognisphere-sh/cognisphere-harness",
  "version": "0.3.16",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cognisphere-sh/cognisphere-harness.git",
    "directory": "packages/harness"
  },
  "bin": {
    "cognisphere": "bin/cognisphere.mjs"
  },
  "files": [
    "bin",
    "src",
    "dist-web",
    "skills",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "tsx watch src/core/main.ts",
    "start": "tsx src/core/main.ts",
    "prepack": "node scripts/prepack.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "check": "tsc --noEmit && eslint src"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.80.6",
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@hono/node-server": "^1.13.7",
    "ajv": "^8.17.1",
    "better-sqlite3": "^11.7.0",
    "croner": "^9.0.0",
    "dotenv": "^16.4.7",
    "hono": "^4.6.14",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2"
  }
