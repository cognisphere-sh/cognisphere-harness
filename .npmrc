# Flat node_modules layout (npm-like) so configs that resolve transitive deps
# keep working. Still uses pnpm's content-addressed store + hardlinks, so the
# per-harness disk-dedup benefit is preserved.
node-linker=hoisted

# @cognisphere-sh packages resolve from / publish to GitHub Packages. The auth
# token is NOT committed — supply it out of band:
#   • locally:  npm config set //npm.pkg.github.com/:_authToken <token>  (→ ~/.npmrc)
#   • CI:       the publish workflow appends the token line from GITHUB_TOKEN
# (read:packages to install, write:packages to publish).
@cognisphere-sh:registry=https://npm.pkg.github.com
