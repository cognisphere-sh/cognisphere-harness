#!/usr/bin/env node
/**
 * telegram-cli — thin wrapper around the Telegram Bot API.
 * Reads TELEGRAM_BOT_TOKEN from env (injected by the harness via secrets.json).
 *
 * Subcommands:
 *   send-message   --chat-id <ID> --text "..." [--reply-to <msgId>] [--parse-mode Markdown|HTML]
 *   send-file      --chat-id <ID> --file <path> --type <photo|document|voice|video|audio>
 *                                 [--caption "..."] [--reply-to <msgId>]
 *   edit-message   --chat-id <ID> --message-id <ID> --text "..." [--parse-mode ...]
 *   delete-message --chat-id <ID> --message-id <ID>
 *   send-reaction  --chat-id <ID> --message-id <ID> --emoji "👍"
 */
import { argv, exit } from "node:process";
import { readFile } from "node:fs/promises";
import { basename } from "node:path";

// Decode literal escape sequences (\n, \t, \r) that arrive as backslash+letter
// when callers pass them inside shell double-quotes. Without this, Telegram
// renders "\n" as visible text instead of a line break.
function decodeEscapes(s) {
  if (typeof s !== "string") return s;
  return s.replace(/\\([ntr\\])/g, (_, ch) =>
    ch === "n" ? "\n" : ch === "t" ? "\t" : ch === "r" ? "\r" : "\\",
  );
}

function parseFlags(args) {
  const flags = {};
  for (let i = 0; i < args.length; i++) {
    const a = args[i];
    if (a.startsWith("--")) {
      const key = a.slice(2);
      flags[key] = args[i + 1] ?? "";
      i++;
    }
  }
  return flags;
}

function getToken() {
  const token = process.env.TELEGRAM_BOT_TOKEN;
  if (!token) {
    console.error("TELEGRAM_BOT_TOKEN not set");
    exit(2);
  }
  return token;
}

async function tg(method, body) {
  const token = getToken();
  const res = await fetch(`https://api.telegram.org/bot${token}/${method}`, {
    method: "POST",
    headers: { "content-type": "application/json" },
    body: JSON.stringify(body),
  });
  const json = await res.json();
  if (!res.ok || !json.ok) {
    console.error(json?.description ?? `HTTP ${res.status}`);
    exit(1);
  }
  return json.result;
}

async function tgMultipart(method, form) {
  const token = getToken();
  const res = await fetch(`https://api.telegram.org/bot${token}/${method}`, {
    method: "POST",
    body: form,
  });
  const json = await res.json();
  if (!res.ok || !json.ok) {
    console.error(json?.description ?? `HTTP ${res.status}`);
    exit(1);
  }
  return json.result;
}

async function main() {
  const [, , cmd, ...rest] = argv;
  const flags = parseFlags(rest);

  switch (cmd) {
    case "send-message": {
      const body = { chat_id: flags["chat-id"], text: decodeEscapes(flags.text) };
      if (flags["reply-to"]) {
        body.reply_parameters = { message_id: Number(flags["reply-to"]) };
      }
      if (flags["parse-mode"]) body.parse_mode = flags["parse-mode"];
      const out = await tg("sendMessage", body);
      console.log(JSON.stringify({ message_id: out.message_id }));
      return;
    }

    case "send-file": {
      const filePath = flags.file;
      const type = flags.type ?? "document";
      const chatId = flags["chat-id"];
      if (!filePath || !chatId) {
        console.error(
          "Usage: send-file --chat-id <ID> --file <path> --type <photo|document|voice|video|audio>",
        );
        exit(2);
      }
      const typeMap = {
        photo: { method: "sendPhoto", field: "photo" },
        document: { method: "sendDocument", field: "document" },
        voice: { method: "sendVoice", field: "voice" },
        video: { method: "sendVideo", field: "video" },
        audio: { method: "sendAudio", field: "audio" },
      };
      const entry = typeMap[type];
      if (!entry) {
        console.error(`Unknown type: ${type}. Use photo|document|voice|video|audio`);
        exit(2);
      }
      const fileData = await readFile(filePath);
      const blob = new Blob([fileData]);
      const form = new FormData();
      form.set("chat_id", chatId);
      form.set(entry.field, blob, basename(filePath));
      if (flags.caption) form.set("caption", decodeEscapes(flags.caption));
      if (flags["reply-to"]) {
        form.set(
          "reply_parameters",
          JSON.stringify({ message_id: Number(flags["reply-to"]) }),
        );
      }
      const out = await tgMultipart(entry.method, form);
      console.log(JSON.stringify({ message_id: out.message_id }));
      return;
    }

    case "edit-message": {
      const body = {
        chat_id: flags["chat-id"],
        message_id: Number(flags["message-id"]),
        text: decodeEscapes(flags.text),
      };
      if (flags["parse-mode"]) body.parse_mode = flags["parse-mode"];
      await tg("editMessageText", body);
      console.log("ok");
      return;
    }

    case "delete-message": {
      await tg("deleteMessage", {
        chat_id: flags["chat-id"],
        message_id: Number(flags["message-id"]),
      });
      console.log("ok");
      return;
    }

    case "send-reaction": {
      await tg("setMessageReaction", {
        chat_id: flags["chat-id"],
        message_id: Number(flags["message-id"]),
        reaction: [{ type: "emoji", emoji: flags.emoji }],
      });
      console.log("ok");
      return;
    }

    default:
      console.error(`Unknown command: ${cmd}`);
      console.error(
        "Commands: send-message, send-file, edit-message, delete-message, send-reaction",
      );
      exit(2);
  }
}

void main();
