{
  "name": "pi-harness-v2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch apps/server/src/main.ts",
    "dev:web": "npm --prefix apps/web run dev",
    "start": "tsx apps/server/src/main.ts",
    "build:web": "npm --prefix apps/web run build",
    "install:web": "npm --prefix apps/web install",
    "typecheck": "tsc --noEmit",
    "typecheck:web": "npm --prefix apps/web run typecheck"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "ajv": "^8.17.1",
    "better-sqlite3": "^11.7.0",
    "croner": "^9.0.0",
    "dotenv": "^16.4.7",
    "hono": "^4.6.14",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
